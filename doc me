package com.tcs.sbi.util;

import java.io.File;
import java.io.FileNotFoundException;
import java.io.FileOutputStream;
import java.io.IOException;
import java.io.InputStream;
import java.io.UnsupportedEncodingException;
import java.nio.file.Files;
import java.util.Vector;
import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;
import com.jcraft.jsch.ChannelSftp;
import com.jcraft.jsch.ChannelSftp.LsEntry;
import com.tcs.sbi.launcher.MandateLauncher;
import com.jcraft.jsch.JSch;
import com.jcraft.jsch.JSchException;
import com.jcraft.jsch.Session;
import com.jcraft.jsch.SftpATTRS;
import com.jcraft.jsch.SftpException;
import org.springframework.web.multipart.MultipartFile;


public class SFTPUtility {

	static Session session = null;
	static ChannelSftp channel;
	@SuppressWarnings("unused")
	private static final Logger log = LogManager.getLogger(MandateLauncher.class);
	public static boolean getsftpConnectiontoRemote() {
		
		
		boolean returnstatus=false;

		//String returnStatus = null;
		try {
			
			String user = MandateUtility.aesDecrypt(MandateLauncher.getKey(), MandateLauncher.getIV(), MandateLauncher.getSftpUsername());
//			String password = MandateUtility.aesDecrypt(MandateLauncher.getKey(), MandateLauncher.getIV(), MandateLauncher.getSftpPwd());
			String privateKeyPath = MandateUtility.aesDecrypt(MandateLauncher.getKey(), MandateLauncher.getIV(), MandateLauncher.getServerPrivateKeypath());
			JSch jsch = new JSch();
			jsch.addIdentity(privateKeyPath.trim());
			session = jsch.getSession(user, MandateLauncher.getSftpHost(),
					Integer.parseInt(MandateLauncher.getSftpPort()));
//			System.out.println(user+" "+privateKeyPath+" "+MandateLauncher.getSftpHost()+" "+MandateLauncher.getSftpPort());
			java.util.Properties config =new java.util.Properties();
			config.put("StrictHostKeyChecking", "no");
			config.put("PreferredAuthentications", "publickey");
			session.setConfig(config);
			session.connect();

			channel = (ChannelSftp) session.openChannel("sftp");
			channel.connect();
			returnstatus=true;

		} catch (JSchException e) {
		    returnstatus = false;
		    log.error("Error during SFTP operation: " +e);
		} catch (NumberFormatException e) {
		    returnstatus = false;
		    log.error("Invalid port number: ");
		} catch (NullPointerException e) {
		    returnstatus = false;
		    log.error("One of the required parameters is null: " );
		} catch (UnsupportedEncodingException e) {
			returnstatus = false;
			log.info("Exception in method getsftpConnectiontoRemote()");
		} 

		return returnstatus;

	}

	public static void disconnect() {
		if (channel != null && channel.isConnected()) {
			channel.disconnect();

		}
		if (session != null && session.isConnected()) {
			session.disconnect();

		}
	}

	
	@SuppressWarnings("unchecked")
	public static boolean upload(String remoteDir,MultipartFile file) {
			
			boolean isuploaded=false;
			InputStream inputstream=null;
			
			try {
				
				channel.cd(remoteDir);
				inputstream=file.getInputStream();
				channel.put(inputstream,file.getOriginalFilename());
				isuploaded=true;
				
			} catch (FileNotFoundException e) {
			    log.error("File not found: " );
			    isuploaded = false;
			} catch (SftpException e) {
			    log.error("SFTP specific error: " );
			    isuploaded = false;
			} catch (IOException e) {
			    log.error("I/O error occurred during file upload: " );
			    isuploaded = false;
			} catch (NullPointerException e) {
			    log.error("A required parameter is null: ");
			    isuploaded = false;
			} 
			finally {
				
				if(inputstream!=null) {
					try {
						inputstream.close();
					} catch (IOException e) {
						log.info("error while closing inputstream");
					}
				}
			}
			
			return isuploaded;
		}

	@SuppressWarnings("unchecked")
	public static boolean isFileAvailable(String remoteDir)
	{
		Vector<ChannelSftp.LsEntry> fileList = null;
		boolean isfileavailable=false;
		try {
			channel.cd(MandateLauncher.getRemoteDir());
		    fileList= channel.ls("*");
			if(fileList.size()>0)
			{
				
				isfileavailable=true;
			}
			else
			{
				
				isfileavailable=false;
			}
		} catch (SftpException e) {
			
			log.info("error while checking for the file");
		}
		
		
		return isfileavailable;
		
	}
	
	
	private static void moveFileToArchive(String remoteFilename) {
		try {

			String sourcePath = MandateLauncher.getRemoteDir()  + remoteFilename;
			String archivePath = MandateLauncher.getArchiveDir()  + remoteFilename;
			log.info("sourcePath "+sourcePath);
			log.info("archivePath "+archivePath);
			//channel.rename(sourcePath, archivePath);
			SftpATTRS attrs = channel.stat(sourcePath);
		    if (attrs != null) {
		        channel.rename(sourcePath, archivePath);
		    } else {
		        log.error("Source file does not exist: " );
		    }
		} catch (SftpException e) {
		    log.error("SFTP specific error during renaming: ");
		} catch (NullPointerException e) {
		    log.error("A required parameter is null: ");
		} 
	}

	@SuppressWarnings("unused")
	private static void getFile(String remoteFilename) throws IOException {
		FileOutputStream out = null;
		InputStream in = null;

		try {
			in = channel.get(remoteFilename);
			File localFile = new File(MandateLauncher.getLocalDir() + File.separator + remoteFilename);
			out = new FileOutputStream(localFile);
			byte[] buffer = new byte[1024];
			int bytereads;
			while ((bytereads = in.read(buffer)) != 1) {
				out.write(buffer, 0, bytereads);

			}

		} catch (FileNotFoundException e) {
		    log.error("File not found during output stream creation: " );
		} catch (SftpException e) {
		    log.error("SFTP specific error: " );
		} catch (IOException e) {
		    log.error("I/O error occurred during file transfer: ");
		} catch (NullPointerException e) {
		    log.error("A required parameter is null: ");
		} 
		
		finally {

			try {
				if (out != null) {
					out.close();
				}
				if (in != null) {
					in.close();
				}
			} catch (IOException e2) {
				log.info("Error closing output stream: " );
			}
		}

	}
}
