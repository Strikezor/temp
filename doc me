public class Manager {
	public static String fileCheckQuery = MandateEncProperties.getInstance().getProperty("FILTER_CHECK_QUERY");
	public static String fileCheckQuery2 = MandateEncProperties.getInstance().getProperty("FILTER_CHECK_QUERY2");
	public static String mandateEncInsertQuery = MandateEncProperties.getInstance().getProperty("INSERT_QUERY");
	public static String mandateEncInsertQuery2 = MandateEncProperties.getInstance().getProperty("INSERT_QUERY2");
	private static final Logger log = LogManager.getLogger(MandateLauncher.class);
	
	public static boolean insertintoMandate_logs(HashMap<String, Object> encmaap, Date date) {
		Connection con = null;
		boolean update = false;
		PreparedStatement prepareState = null;

		try {

			con = ConnectionManager.getConnection();
			prepareState = con.prepareStatement(mandateEncInsertQuery);
			prepareState.setObject(1, encmaap.get("ReferenceNumber"));
			prepareState.setDate(2, new java.sql.Date(System.currentTimeMillis()));
			prepareState.setObject(3, encmaap.get("FileName"));
			prepareState.setObject(4, encmaap.get("FileType"));
			prepareState.setObject(5, encmaap.get("ERROR_CODE"));
			prepareState.setObject(6, encmaap.get("EncryptionType"));
			prepareState.setObject(7, encmaap.get("totalnoofRecords"));
			prepareState.setTimestamp(8, (Timestamp) encmaap.get("fileCopiedTime"));
			prepareState.setObject(9, encmaap.get("Status"));
			prepareState.setObject(10, encmaap.get("statusENC"));
			prepareState.setTimestamp(11, (Timestamp) encmaap.get("lastUpdatedtime"));
			prepareState.setObject(12,encmaap.get("Zone"));
			
			prepareState.executeUpdate();

			update = true;

		} catch (SQLException e) {
			log.info("SQL exception coming for inserting value in table",e);
		} 

		finally {
			try {
				if (prepareState != null) {
					prepareState.close();
				}
				if (con != null) {
					con.close();
				}

			} catch (SQLException e) {
				log.info("Sql exception in closing the db connection",e);
			} 
			
		}
		return update;
	}
	
	public static boolean insertintoMandate_file_logs(HashMap<String, Object> encmaap, Date date) {
		Connection con = null;
		boolean update = false;
		PreparedStatement prepareState = null;

		try {

			con = ConnectionManager.getConnection();
			prepareState = con.prepareStatement(mandateEncInsertQuery2);
			prepareState.setObject(1, encmaap.get("FileName"));
			prepareState.setObject(2, encmaap.get("FolderName"));
			prepareState.setObject(3, encmaap.get("ERROR_CODE"));
			prepareState.setDate(4, new java.sql.Date(System.currentTimeMillis()));
			prepareState.setTimestamp(5, (Timestamp) encmaap.get("lastUpdatedtime"));
			prepareState.setString(6, "ENC");
			prepareState.setObject(7,encmaap.get("Zone"));
			prepareState.executeUpdate();

			update = true;

		} catch (SQLException e) {
			log.info("SQL exception coming for inserting value in table",e);
		}

		finally {
			try {
				if (prepareState != null) {
					prepareState.close();
				}
				if (con != null) {
					con.close();
				}

			} catch (SQLException e) {
				log.info("Sql exception in closing the db connection",e);
			}
		}
		return update;
	}

	public static boolean isFilepreviouslyProcessed(String filename, Date date) {
		boolean isProcessed = false;
		Connection con = null;
		PreparedStatement prepareState = null;
		ResultSet resultset = null;
		PreparedStatement prepareState2 = null;
		ResultSet resultset2 = null;

		try {
			con = ConnectionManager.getConnection();
			prepareState = con.prepareStatement(fileCheckQuery);
			prepareState.setString(1, filename.trim());
			prepareState.setDate(2, new java.sql.Date(date.getTime()));
			
			resultset = prepareState.executeQuery();
		
			if (resultset !=null && resultset.next()) {
				int count = resultset.getInt(1);
				if (count > 0) {
					prepareState2 = con.prepareStatement(fileCheckQuery2);
					prepareState2.setString(1, filename.trim());
					prepareState2.setDate(2, new java.sql.Date(date.getTime()));
					
					resultset2 = prepareState2.executeQuery();
					while (resultset2.next()) {
						if(resultset2.getString("ERROR_CODE")==null) {
							isProcessed = true;
							return true;
						}
					}
				}
			}
		} catch (SQLException e) {
			isProcessed=true;
			log.info("Sql exception in checking for proccessed file",e);
		
		} finally {
			try {
				if (resultset != null) {
					resultset.close();
				}
				if (prepareState != null) {
					prepareState.close();
				}
				if (con != null) {
					con.close();
				}

			} catch (SQLException e2) {
				log.info("Sql exception in closing the db connection",e2);
			}
		}

		return isProcessed;
	}
}




