	public static String aesDecrypt(String key, String initVector, String encrypted)
			throws UnsupportedEncodingException {
		byte[] keyb = keyToB(key);
		byte[] ivb = keyToB(initVector);
		String dec = decrypt1(keyb, ivb, encrypted);
		return dec;
