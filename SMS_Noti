public class ConnectionManager {

	public static BoneCP connectionPool = null;

	private static String dbUser, dbPwd, dbUrl;
	private static int minConn, maxConn, partitionCount, idleMaxAge, idleAgeTestTime;
	static {
		System.setProperty("config", "/AadeshApp/JAR/SMS_NOTIFICATION_METADATA/PROPERTY_FILE/");
//		System.setProperty("config", "E:/Aadesh/Keys/AadesshEISENCCER/AadeshNEKeys/SMSPropertyFile/");
		
		String encDbURL = PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.DBURL.toString());
		String encDbUser = PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.DBUSER.toString());
		String encDbPd  = PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.DBPWD.toString());
		String iv1 = PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.IV.toString());
		String key1 = PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.Key.toString());
		
		try {
			dbPwd = AESdecrypt.aesDecrypt(key1, iv1, encDbPd);
			dbUrl = AESdecrypt.aesDecrypt(key1, iv1, encDbURL);
			dbUser = AESdecrypt.aesDecrypt(key1, iv1, encDbUser);
		} catch (IOException e) {
			SmsNotificationLauncher.createLog("Error occured while getting db details");
		}

		minConn = Integer.parseInt(PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.MINCONN.toString()));
		maxConn = Integer.parseInt(PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.MAXCONN.toString()));
		partitionCount = Integer.parseInt(PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.PARTITION_COUNT.toString()));
		idleMaxAge = Integer.parseInt(PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.IDLE_MAX_AGE.toString()));
		idleAgeTestTime = Integer.parseInt(PropertyFileReader.getPropertyKeyValue(AadeshConstants.NE_PROPERTY_FILENAME.toString(), AadeshConstants.IDLE_AGE_TEST_TIME.toString()));	

		


	}

	public static void configureConnPool() {
		try {

			Class.forName("oracle.jdbc.driver.OracleDriver");
			BoneCPConfig boneCpConfig = new BoneCPConfig();
			Properties prop = new Properties();
			prop.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_ENCRYPTION_LEVEL, "REQUIRED");
			prop.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_ENCRYPTION_TYPES, "AES256");
			prop.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_CHECKSUM_LEVEL, "REQUIRED");
			prop.setProperty(OracleConnection.CONNECTION_PROPERTY_THIN_NET_CHECKSUM_TYPES, "SHA256");
			boneCpConfig.setProperties(prop);

			boneCpConfig.setJdbcUrl(dbUrl);
			boneCpConfig.setUsername(dbUser);
			boneCpConfig.setPassword(dbPwd);

			boneCpConfig.setMinConnectionsPerPartition(minConn);
			boneCpConfig.setMaxConnectionsPerPartition(maxConn);
			boneCpConfig.setPartitionCount(partitionCount);
			boneCpConfig.setIdleMaxAgeInMinutes(idleMaxAge);
			boneCpConfig.setIdleConnectionTestPeriodInMinutes(idleAgeTestTime);
			
 			connectionPool = new BoneCP(boneCpConfig);

		} catch (IOException | ClassNotFoundException e) {
			SmsNotificationLauncher.createLog("Error while configuring conn pool");
		} catch (Exception e) {
			SmsNotificationLauncher.createLog("Error while setting bonecp properties");
		}
	}

	public static Connection getConnection() {
		Connection conn = null;
		try {
			conn = getConnectionPool().getConnection();

			conn.setAutoCommit(false);
		} catch (SQLException e) {
			SmsNotificationLauncher.createLog("sql exception occured while getting connection");
		}
		return conn;
	}

	public static void shutdownConnectionPool() {
		BoneCP connPool = ConnectionManager.getConnectionPool();
		if (connPool != null) {
			connPool.shutdown();
		}
	}

	public static void closeStatement(PreparedStatement stmt) {
		try {
			if (stmt != null)
				stmt.close();

		} catch (SQLException e) {
			SmsNotificationLauncher.createLog("sql exception occured while closing statement");
		}
	}

	public static void closeResultSet(ResultSet rSet) {
		try {
			if (rSet != null)
				rSet.close();

		} catch (SQLException e) {
			SmsNotificationLauncher.createLog("sql exception occured while closing result set");
		}
	}

	public static void closeConnection(Connection conn) {
		try {
			if (conn != null) {
				conn.close();
				getTotalFreeConn();

			}
		} catch (SQLException e) {
			SmsNotificationLauncher.createLog("sql exception occured while closing conneciton");
		}
	}

	public static BoneCP getConnectionPool() {
		return connectionPool;
	}

	public static void setConnectionPool(BoneCP connectionPool) {
		ConnectionManager.connectionPool = connectionPool;
	}

	public static void getTotalFreeConn() {

	}

	public static void commitConnection(Connection c) {
		try {
			c.commit();

		} catch (SQLException q) {
			SmsNotificationLauncher.createLog("sql exception occured while commiting connection");
		}
	}

}



