			StringBuilder sb = new StringBuilder();
			while (sb.length() + balance.length() < 17) {
				sb.append("0");
			}

			// Append the modified balance
			sb.append(balance);

			// Append the '+' sign at the end
			sb.append("+");
			return sb.toString();
		}

	}

	public static String formatStringLength(int zerosToAdd, String str) {
		StringBuilder leadingZeros = new StringBuilder();
		for (int i = 0; i < zerosToAdd; i++) {
