package com.tcs.sms.main;

import java.io.IOException;
import java.security.GeneralSecurityException;
import java.sql.SQLException;
import java.util.Base64;
import java.util.List;
import java.util.Map;
import org.slf4j.LoggerFactory;

import com.ibm.mq.MQException;
import com.ibm.mq.MQQueueManager;
import com.tcs.sms.connectionManager.SM01_Manager;
import com.tcs.sms.launcher.SmsNotificationLauncher;
import com.tcs.sms.service.AESdecrypt;
import com.tcs.sms.service.MQUtil;
import com.tcs.sms.service.StringGenerationUtility;

public class SmsNotificationStart implements Runnable {

	private static org.slf4j.Logger log = LoggerFactory.getLogger(SmsNotificationLauncher.class);

	private List<Map<String, String>> data = null;
	private String key;
	private String IV;
	private String hash;
	private String EncryptedString;
	private String EncryptedHash;
	private String Encryptedkeys;
	private String KeyIV;
	private String neData;
	MQQueueManager queueManager;
	private boolean dbupdate;

	public SmsNotificationStart() {
		super();
	}

	@Override
	public void run() {

		MQUtil MQENV = new MQUtil();

		try {
			//DataBase 
			data = SM01_Manager.fetchDatafromdb();

		} catch (SQLException e1) {

			log.info("Error while fetching data from db");
		}

		if (!data.isEmpty()) {

			try {
				//MQ connection code
				System.setProperty("javax.net.ssl.trustStore",
						(AESdecrypt.aesDecrypt1(SmsNotificationLauncher.mqStore)));
				System.setProperty("javax.net.ssl.trustStorePassword", "password");
				System.setProperty("com.ibm.mq.cfg.useIBMCipherMappings", "false");
//				System.setProperty("javax.net.ssl.trustStorePassword", "changeit");
				System.setProperty("javax.net.ssl.trustStoreType", "JKS");
				queueManager = MQENV.connectToMQ(SmsNotificationLauncher.getHostName(),
						SmsNotificationLauncher.getPort(), SmsNotificationLauncher.getChannel(),
						SmsNotificationLauncher.getFipsRequired(), SmsNotificationLauncher.getCipherSuite(),
						SmsNotificationLauncher.getLocalQMgr());
				log.info("Connected to MQ Queue Manager: " + queueManager.getName());

			} catch (IOException | MQException e) {
				log.info("IO exception occured while setting property");
			} 

			try {

				for (Map<String, String> row : data) {
					String formattedString = StringGenerationUtility.fromatData(row);
					log.info("GENERATED STRING : " + formattedString);
					hash = StringGenerationUtility.generateHash(formattedString);
					EncryptedHash = StringGenerationUtility.encryptHash(hash, SmsNotificationLauncher.getPrivateKey());
					key = StringGenerationUtility.getKEY(32);
					IV = StringGenerationUtility.getIV(16);
					EncryptedString = StringGenerationUtility.encryptData(key, IV, formattedString);
					KeyIV = Base64.getEncoder().encodeToString(key.getBytes()).concat("|*|")
							.concat(Base64.getEncoder().encodeToString(IV.getBytes()));
					Encryptedkeys = StringGenerationUtility.encryptWithPublicKey(KeyIV,
							SmsNotificationLauncher.getPublicKey());
					neData = EncryptedHash.concat("|*|").concat(Encryptedkeys).concat("|*|").concat(EncryptedString);

					if (queueManager != null) {
					//if(true) {
						log.info("ne data :- "+neData);
						MQENV.sendMessage(queueManager, SmsNotificationLauncher.getNeCbsQueue(), neData);
						log.info("Message sent: " + neData);
						dbupdate = SM01_Manager.updateSmo1(row.get("sequence"));
						SM01_Manager.updateSm01(formattedString,row.get("sequence"));
						if (dbupdate) {
							log.info("SM01 is updated for sequence No : " + row.get("sequence"));
							System.err.println("SM01 is updated for sequence No : " + row.get("sequence"));
						} else {
							log.info("Unable to update SM01 for sequence No : " + row.get("sequence"));
						}

					} else {
						log.info("Unable to push data to NE end.");
					}

				}

			} catch (IOException | GeneralSecurityException e) {
				log.info("exception occured while sending msg");
			} catch (Exception e) {
				log.info("Exception occured");
			} finally {
				try {
					queueManager.disconnect();
					log.info("Data is not available to send. MQ Disconnected Successfully");
				} catch (MQException e) {
					log.info("MQ exception occured while disconnecting connection");
				}
			}

		} else {
			log.info("Data is not available to send.");
			try {
				Thread.sleep(1000);
			} catch (InterruptedException e) {
				log.info("Data not available to send");
			}
		}

	}

}



