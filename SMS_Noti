	public static String encryptData(String key, String initVector, String data) {
        try {
            // Convert key and IV to bytes
            byte[] keyBytes = key.getBytes(StandardCharsets.UTF_8);
            byte[] ivBytes = initVector.getBytes(StandardCharsets.UTF_8);

            // AES key must be 128, 192, or 256 bits -> 16, 24, or 32 bytes
            SecretKeySpec secretKey = new SecretKeySpec(keyBytes, "AES");

            // IV must match block size (16 bytes for AES)
            IvParameterSpec ivSpec = new IvParameterSpec(ivBytes);

            // Create Cipher instance for AES/CBC/PKCS5Padding
            Cipher cipher = Cipher.getInstance("AES/CBC/PKCS5Padding");
            cipher.init(Cipher.ENCRYPT_MODE, secretKey, ivSpec);

            // Encrypt the data
            byte[] encryptedBytes = cipher.doFinal(data.getBytes(StandardCharsets.UTF_8));
            return Base64.getEncoder().encodeToString(encryptedBytes);

        } catch (NoSuchAlgorithmException | NoSuchPaddingException | IllegalBlockSizeException | BadPaddingException | InvalidKeyException | InvalidAlgorithmParameterException ex) {
        	SmsNotificationLauncher.createLog("Exception occured in encrypting string");
            return null;
        }
