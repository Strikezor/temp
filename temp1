				logger.error(e.getMessage());
			}
			logger.info("Final response decrypted. Response size: {} characters", decryptedResponse.length());
			logger.info("Final decrypted response: {}", decryptedResponse);
			List<Map<String, Object>> nameIdBeans = (List<Map<String, Object>>) response.get("name_IdBeans");
			String responseCode = (String) response.get("responseCode");
			String responseMsg = (String) response.get("responseMsg");
