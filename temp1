	private static String sendPostRequest(String url, String jsonBody, String token) throws IOException {
		URL obj = new URL(url);
		HttpURLConnection con = (HttpURLConnection) obj.openConnection();

		con.setRequestMethod("POST");
		con.setRequestProperty("Content-Type", "application/json");
		con.setRequestProperty("Accept", "application/json");

		// Set the token header empty only
		con.setRequestProperty("signedSenderTokenHash", token);

		con.setDoOutput(true);
		con.setConnectTimeout(15000);
		con.setReadTimeout(45000);

		logger.debug("Sending POST request to: {} with body size: {} characters", url, jsonBody.length());

		try (OutputStream os = con.getOutputStream()) {
			byte[] input = jsonBody.getBytes(StandardCharsets.UTF_8);
			os.write(input, 0, input.length);
		}

		int responseCode = con.getResponseCode();
		logger.debug("HTTP Response Code: {}", responseCode);

		if (responseCode != 200) {
			// Log the response body for debugging 400 errors
			try (BufferedReader br = new BufferedReader(
					new InputStreamReader(con.getErrorStream(), StandardCharsets.UTF_8))) {
				StringBuilder errorResponse = new StringBuilder();
				String responseLine;
				while ((responseLine = br.readLine()) != null) {
					errorResponse.append(responseLine.trim());
				}
				logger.error("HTTP Error Response: {}", errorResponse.toString());
			}
			throw new IOException("HTTP error code: " + responseCode);
		}

		try (BufferedReader br = new BufferedReader(
				new InputStreamReader(con.getInputStream(), StandardCharsets.UTF_8))) {
			StringBuilder response = new StringBuilder();
			String responseLine;
			while ((responseLine = br.readLine()) != null) {
				response.append(responseLine.trim());
			}
			logger.debug("Response received. Size: {} characters", response.toString());
			return response.toString();
		}
	}

	public static EDMS_Response reuseToken(String signedSenderTokenHashWithID, RequestBean request, Gson g,
			String edmsURL) throws NoSuchProviderException {
		Gson gson = null;
		if (g != null)
			gson = g;
		else {
			gson = new GsonBuilder().serializeNulls().disableHtmlEscaping().setPrettyPrinting().create();
		}

		EDMS_Response finalResponse = new EDMS_Response();
		String decryptedResponse = null;
		String finalJSONReq = gson.toJson(request);

		logger.info("final request : {\r\n" + "  \"channelID\":" + " \"" + request.getApplicationID() + "\",\r\n"
				+ "  \"branchCode\":" + " \"" + request.getBranchCode() + "\",\r\n" + "  \"uniqueIdentifier\":" + " \""
				+ request.getUniqueIdentifier() + "\",\r\n" + "  \"documents\": [" + "\r\n" + "    {\r\n"
				+ "      \"documentName\":" + " \"" + request.getDocuments().get(0).getDocumentName() + "\"\r\n"
				+ "    }\r\n  ]\r\n}");

		SecretKey aesKey = EDMSEncryption.generateAESkey();
		PublicKey edmsServerPublicKey = null;
		edmsServerPublicKey = EDMSEncryption.getPublicKey(hostPublic);
		;

		String encryptedRequest = null;
		logger.info("Encrypting final request with AES key: {}", aesKey);
		encryptedRequest = EDMSEncryption.encryptRawJSON(aesKey, edmsServerPublicKey, finalJSONReq);

		try {
			SSLUtil.turnOffSSLChecking();
		} catch (NoSuchAlgorithmException e) {
			logger.error("SSL configuration error - NoSuchAlgorithmException", e);
			return null;
		} catch (KeyManagementException e) {
			logger.error("SSL configuration error - KeyManagementException", e);
			return null;
		}

		String finalResponseString = null;
		try {
			logger.info("--------------------------- Final EDMS Call Started ---------------------------");
			finalResponseString = sendPostRequest(edmsURL, encryptedRequest, signedSenderTokenHashWithID);
			logger.info("---------------------------  Final EDMS Call Ended  ---------------------------");
			logger.info("Final EDMS call completed successfully. Response length: {} characters",
					finalResponseString.length());
		} catch (Exception e) {
			logger.error("--------------------------- UNABLE TO FETCH EDMS RESPONSE ---------------------------"
					+ e.getMessage());
			return null;
		}

		PrivateKey privateKey = null;
		privateKey = EDMSEncryption.getPrivateKey(privateKey_DigISign);

		if (finalResponseString != null && !finalResponseString.isEmpty()) {
			decryptedResponse = EDMSEncryption.decryptResponse(finalResponseString, privateKey);
			Map<String, Object> response = new HashMap<>();
			ObjectMapper mapper = new ObjectMapper();
			try {
				response = mapper.readValue(decryptedResponse, new TypeReference<Map<String, Object>>() {
				});
