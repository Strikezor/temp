			throws StringIndexOutOfBoundsException, IllegalArgumentException {
		if (inputStr == null) {
			return null;
		}

		String digitsOnly = null;
//		try {
			digitsOnly = removeLeadingZeros(inputStr.trim()) // returns "0" if inputStr contains all 0s
					.replaceAll("\\D", ""); // removes all non-digit characters

			if (digitsOnly.isEmpty() || digitsOnly.equals("0")) {
