	public static void processXMLFiles(String sourceFolderPath, String destinationFailFolderPathAmmend,String destinationFailFolderPathCreate,
			String succesFolderPathforAmmend,String succesFolderPathforCreate,String destinationFailFolderPathCancel,String succesFolderPathforCancel) {
		File sourceFolder = new File(sourceFolderPath);
		File destinationFailFolderAmmend = new File(destinationFailFolderPathAmmend);
		File destinationFailFolderCreate = new File(destinationFailFolderPathCreate);
		File destinationSuccessFolder = new File(succesFolderPathforAmmend);
		File destinationSuccessFolderForCreate = new File(succesFolderPathforCreate);
		File destinationFailFolderCancel = new File(destinationFailFolderPathCancel);
		File destinationSuccessFolderForCancel = new File(succesFolderPathforCancel);

		// Check if source folder exists and is a directory
		if (!sourceFolder.exists() || !sourceFolder.isDirectory()) {
			log.info("Source folder does not exist or is not a directory.");
			return;
		}

		// Check if destination folder exists, if not create it
		if (!destinationFailFolderAmmend.exists()) {
			destinationFailFolderAmmend.mkdirs();
		}
		
		if (!destinationFailFolderCreate.exists()) {
			destinationFailFolderCreate.mkdirs();
		}

		if (!destinationSuccessFolder.exists()) {
			destinationSuccessFolder.mkdirs();
		}

		File[] directories = sourceFolder.listFiles(File::isDirectory);
		if (directories != null) {
			for (File dir : directories) {
				Path sourcepath = dir.toPath();
				Path destinationpath = Paths.get(Pain_backup_path+ dir.getName());
				if (!Files.exists(destinationpath)) {
					try {
						
						Files.createDirectories(destinationpath);
						log.info("directory for copy folder created");
					} catch (IOException e) {
						log.error("IoException ocuured");
					}
				}

				// Walk through the source directory and copy each file and subdirectory
				try {
					Files.walk(sourcepath).forEach(sourcePath -> {
						Path destinationPath = destinationpath.resolve(sourcepath.relativize(sourcePath));
						try {
							if (Files.isDirectory(sourcePath)) {
								// Create the directory in the target location
								Files.createDirectories(destinationPath);
							} else {
								// Copy the file to the target location
								Files.copy(sourcePath, destinationPath, StandardCopyOption.REPLACE_EXISTING);
								
							}
							
						} catch (IOException e) {
							log.error("Failed to copy " + sourcePath + ": " + e.getMessage()+"for foldername:-"+dir.getName());
						}
					});  
					log.info(dir.getName()+" Succesfully copied in the backup folder");
				} catch (IOException e1) {
					log.error("IoException ocuured");
				}
				// Check if the directory name contains "Ammend"
				String folderName=dir.getName();
				String[] dirName = dir.getName().split("-");
				int datedir = Integer.parseInt(dirName[3]);
				int daydir = datedir / 1000000;
				int monthdir = (datedir % 1000000) / 10000;
				String yeardir = Integer.toString(datedir % 10000);
				if (dir.getName().contains("AMEND") && dir.getName().contains("MMS") && dir.getName().contains("SBIN")
						&& daydir <= 31 && monthdir <= 12 && yeardir.length() == 4) {
					log.info("folder found for Pain10"+folderName);
					
					File[] files = dir.listFiles((d, name) -> name.endsWith(".xml"));
					if (files != null) {
						for (File file : files) {
							log.info("Xml File found for process, File name: "+file.getName()+" in Folder: "+folderName);
							String[] FileName = file.getName().split("-");
							int date = Integer.parseInt(FileName[4]);
							int day = date / 1000000;
							int month = (date % 1000000) / 10000;
							String year = Integer.toString(date % 10000);
							//log.info(day + "   " + month + "  " + year);

							if (FileName[0].equals("MMS") && FileName[1].equals("AMEND")
									&& FileName[6].equals("INP.xml") && day <= 31 && month <= 12
									&& year.length() == 4) {
								log.info("Validation completed for File Name: "+file.getName());
								XML_READER xmlReader = new XML_READER();
								try {
									Pain_10_Document data = xmlReader.readXml10(file);

									if (data != null && data.getMndtAmdmntReq() != null
											&& data.getMndtAmdmntReq().getGrpHdr() != null) {

										String fileName = file.getName();
										String immagename1 = fileName.substring(0, fileName.length() - 8)
												+ "_front.tif";
										String immagename11 = fileName.substring(0, fileName.length() - 8)
												+ "_front.tiff";
										String immagename2 = fileName.substring(0, fileName.length() - 8)
												+ "_detailfront.jpg";
										String immagename22 = fileName.substring(0, fileName.length() - 8)
												+ "_detailfront.jpeg";

										File immage1 = null, immage2 = null;
										File[] imageFiles = dir.listFiles();
										for (File file2 : imageFiles) {
											if (file2.getName().equalsIgnoreCase(immagename1)) {
												immage1 = file2;
											} else if (file2.getName().equalsIgnoreCase(immagename11)) {
												immage1 = file2;
											} else if (file2.getName().equalsIgnoreCase(immagename2)) {
												immage2 = file2;
											} else if (file2.getName().equalsIgnoreCase(immagename22)) {
												immage2 = file2;
											}
										}

										if (immage1 != null) {
											immagename1 = immage1.getName();
										} else {
											immagename1 = " ";
										}

										if (immage2 != null) {
											immagename2 = immage2.getName();
										} else {
											immagename2 = " ";
										}

										UpdateTableForAmend.updateTableWithDocument(data, fileName, dir.getName(), immagename1, immagename2,
												destinationFailFolderAmmend, destinationSuccessFolder, dir);

									} else {
										log.info("Data or required fields are null.");
									}
								} catch (JAXBException e) {
									log.error("Some error happend in XML file: "+file.getName());
								}

							} else {
								log.info("Validation failed for file: "+file.getName());
							}
						}
					} else {
						log.info("No files found in Folder: "+folderName);
					}
				} else if (dir.getName().contains("CREATE")&& dir.getName().contains("MMS") && dir.getName().contains("SBIN")
						&& daydir <= 31 && monthdir <= 12 && yeardir.length() == 4) {
					log.info("Folder found for Pain_09 method: "+folderName);
					File[] files = dir.listFiles((d, name) -> name.endsWith(".xml"));
					if (files != null) {
						for (File file : files) {
							log.info("Xml File found for process, File name: "+file.getName()+" in Folder: "+folderName);
							String[] FileName = file.getName().split("-");
							int date = Integer.parseInt(FileName[4]);
							int day = date / 1000000;
							int month = (date % 1000000) / 10000;
							String year = Integer.toString(date % 10000);
							//log.info(day + "   " + month + "  " + year);

							if (FileName[0].equals("MMS") && FileName[1].equals("CREATE")
									&& FileName[6].equals("INP.xml") && day <= 31 && month <= 12
									&& year.length() == 4) {
								log.info("Validation completed for File Name: "+file.getName());
								XML_READER xmlReader = new XML_READER();
								try {
									Pain_09_Document data = xmlReader.readXml9(file);
									if (data != null && data.getMndtInitnReq() != null
											&& data.getMndtInitnReq().getGrpHdr() != null) {
									String fileName = file.getName();
									String immagename1 = fileName.substring(0, fileName.length() - 8)
											+ "_front.tif";
									String immagename11 = fileName.substring(0, fileName.length() - 8)
											+ "_front.tiff";
									String immagename2 = fileName.substring(0, fileName.length() - 8)
											+ "_detailfront.jpg";
									String immagename22 = fileName.substring(0, fileName.length() - 8)
											+ "_detailfront.jpeg";

									File immage1 = null, immage2 = null;
									File[] imageFiles = dir.listFiles();
									for (File file2 : imageFiles) {
										if (file2.getName().equalsIgnoreCase(immagename1)) {
											immage1 = file2;
										} else if (file2.getName().equalsIgnoreCase(immagename11)) {
											immage1 = file2;
										} else if (file2.getName().equalsIgnoreCase(immagename2)) {
											immage2 = file2;
										} else if (file2.getName().equalsIgnoreCase(immagename22)) {
											immage2 = file2;
										}
									}

									if (immage1 != null) {
										immagename1 = immage1.getName();
									} else {
										immagename1 = " ";
									}

									if (immage2 != null) {
										immagename2 = immage2.getName();
									} else {
										immagename2 = " ";
									}
									UpdateTableForCreate update=new UpdateTableForCreate();
									update.updateTableWithDocument2(data,file.getName(),dir.getName(),immagename1,immagename2,destinationFailFolderCreate,destinationSuccessFolderForCreate,dir);
									} else {
										log.info("Data or required fields are null.");
									}
									
								} catch (JAXBException e) {
									log.error("Some error happend in XML file: "+file.getName()+e);
								}

							} else {
							log.info("Validation failed for file: "+file.getName());
							}
						}
					} else {
						log.info("No files found in Folder: "+folderName);
					}
				} else if(dir.getName().contains("CANCEL")&& dir.getName().contains("MMS") && dir.getName().contains("SBIN")
						&& daydir <= 31 && monthdir <= 12 && yeardir.length() == 4) {
					log.info("Folder found for Pain_09 method: "+folderName);
					File[] files = dir.listFiles((d, name) -> name.endsWith(".xml"));
					if (files != null) {
						for (File file : files) {
							log.info("Xml File found for process, File name: "+file.getName()+" in Folder: "+folderName);
							String[] FileName = file.getName().split("-");
							int date = Integer.parseInt(FileName[4]);
							int day = date / 1000000;
							int month = (date % 1000000) / 10000;
							String year = Integer.toString(date % 10000);
							//log.info(day + "   " + month + "  " + year);

							if (FileName[0].equals("MMS") && FileName[1].equals("CANCEL")
									&& FileName[6].equals("INP.xml") && day <= 31 && month <= 12
									&& year.length() == 4) {
								log.info("Validation completed for File Name: "+file.getName());
								XML_READER xmlReader = new XML_READER();
								try {
									Pain_11_document data = xmlReader.readXml11(file);
									if(data!=null && data.getMndtCxlReq()!=null && data.getMndtCxlReq().getGrpHdr()!=null && data.getMndtCxlReq().getUndrlygCxlDtls()!=null) {
										UpdateTableForCancel update=new UpdateTableForCancel();
										update.updateTableWithDocument3(data,file.getName(),dir.getName(),destinationFailFolderCancel,destinationSuccessFolderForCancel,dir);
									} else {
										log.info("Data or required fields are null.");
									}
								} catch (JAXBException e) {
									log.error("Some error happend in XML file: "+file.getName());
								}
							} else {
								log.info("Validation failed for file: "+file.getName());
								}
							}
						} else {
							log.info("No files found in Folder: "+folderName);
						}
				}

				
				//|| files[0].equals("Thumbs.db")
				String[] files = dir.list();
				if (files == null || files.length == 0 ) {
					if (dir.delete()) {
						log.info("Directory deleted successfully: "+folderName);
					} else {
						log.info("Failed to delete the directory: "+folderName);
					}
				} else {
					Path sourcepath2 = dir.toPath();
					String destinationFailFolderPath=null;
					if(dir.getName().contains("CREATE")) {
						destinationFailFolderPath=destinationFailFolderPathCreate;
					} else if(dir.getName().contains("AMEND")) {
						destinationFailFolderPath=destinationFailFolderPathAmmend;
					}
					Path targetPath = Paths.get(destinationFailFolderPath, dir.getName());

					// Move the directory
					try {
//						Files.move(sourcePath, targetPath,StandardCopyOption.REPLACE_EXISTING);
						Files.walk(sourcepath2).forEach(sourcePath -> {
							Path destinationPath = destinationpath.resolve(sourcepath.relativize(sourcePath));
							try {
								if (Files.isDirectory(sourcePath)) {
									// Create the directory in the target location
									Files.createDirectories(destinationPath);
								} else {
									// Copy the file to the target location
									Files.copy(sourcePath, destinationPath, StandardCopyOption.REPLACE_EXISTING);
									
								}
								
							} catch (IOException e) {
								log.error("Failed to copy " + sourcePath + ": " + e.getMessage()+"for foldername:-"+dir.getName());
							}
						});  
						Files.walkFileTree(sourcepath2, new SimpleFileVisitor<Path>() {
						    @Override
						    public FileVisitResult visitFile(Path file, BasicFileAttributes attrs) throws IOException {
						        Files.delete(file);
						        return FileVisitResult.CONTINUE;
						    }

						    @Override
						    public FileVisitResult postVisitDirectory(Path dir, IOException exc) throws IOException {
						        Files.delete(dir);
						        return FileVisitResult.CONTINUE;
						    }
						});   
						log.info("Directory: "+folderName+" moved to: " + targetPath);
					} catch (IOException e) {
						// TODO Auto-generated catch block
						log.error("Failed to move file: "+folderName+e);
					}

				}

			}
		} else {
			log.info("No files to process");
		}
	}

	
}
class Helper extends TimerTask{
	private static final String sourceFolderPath = ExtractProp.getInstance().getExtractProperty("sourceFolderPath");
	private static final String destinationFailFolderPathAmmend = ExtractProp.getInstance().getExtractProperty("destinationFailFolderPathAmmend");
	private static final String destinationFailFolderPathCreate = ExtractProp.getInstance().getExtractProperty("destinationFailFolderPathCreate");
	private static final String destinationFailFolderPathCancel = ExtractProp.getInstance().getExtractProperty("destinationFailFolderPathCancel");
	private static final String succesFolderPathforAmmend = ExtractProp.getInstance().getExtractProperty("succesFolderPathforAmmend");
	private static final String succesFolderPathforCreate = ExtractProp.getInstance().getExtractProperty("succesFolderPathforCreate");
	private static final String succesFolderPathforCancel = ExtractProp.getInstance().getExtractProperty("succesFolderPathforCancel");
	private static final Logger log = LogManager.getLogger(Pain_09_10_main.class);
	@Override
	public void run() {
		File sourceFolder = new File(sourceFolderPath);
		File[] directories = sourceFolder.listFiles(File::isDirectory);
		if (directories.length == 0) {
			log.info("No files to process");
		} else {
			Pain_09_10_main.processXMLFiles(sourceFolderPath, destinationFailFolderPathAmmend,destinationFailFolderPathCreate, succesFolderPathforAmmend,succesFolderPathforCreate,destinationFailFolderPathCancel,succesFolderPathforCancel);
		}
	}
}






