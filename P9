package com.sbi.tcs.pain10Util;

import java.io.FileWriter;
import java.io.IOException;
import java.math.BigInteger;
import java.nio.file.Files;
import java.nio.file.Paths;

import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;


public class Pain10_sequence {
    // Define 10^36 as the max limit (36 nines: 999...999)
    private static final BigInteger MAX_SEQUENCE = new BigInteger("9".repeat(36));
    private static final String SEQUENCE_FILE_PATH = ExtractProp.getInstance().getExtractProperty("Sequence_file_path");
    private static final Logger log = LogManager.getLogger(Pain10_sequence.class);
    public BigInteger getSequence() {
        BigInteger sequenceNumber = readSequenceNumber();

        // Ensure sequence number is within valid range
        if (sequenceNumber.compareTo(MAX_SEQUENCE) > 0) {
            sequenceNumber = BigInteger.ONE; // Reset to 1 after max
        }

        saveSequenceNumber(sequenceNumber.add(BigInteger.ONE));
        return sequenceNumber;
    }

    private static BigInteger readSequenceNumber() {
        try {
            // Check if the sequence file exists
            if (!Files.exists(Paths.get(SEQUENCE_FILE_PATH))) {
                // Create file with initial value 1
                saveSequenceNumber(BigInteger.ONE);
                return BigInteger.ONE;
            }

            // Read current sequence number from file
            String sequenceStr = new String(Files.readAllBytes(Paths.get(SEQUENCE_FILE_PATH))).trim();
            return new BigInteger(sequenceStr);
        } catch (IOException | NumberFormatException e) {
            // Return default value on error
            return BigInteger.ONE;
        }
    }

    private static void saveSequenceNumber(BigInteger sequenceNumber) {
        try (FileWriter writer = new FileWriter(SEQUENCE_FILE_PATH)) {
            writer.write(sequenceNumber.toString());
        } catch (IOException e) {
        	log.info("can not save sequence");
        }
    }
}   




