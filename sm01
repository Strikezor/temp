class Helper extends TimerTask {
	private static String DB_URL = ExtractProp.getInstance().getExtractProperty("DB_URL");
	private static String USER = ExtractProp.getInstance().getExtractProperty("USER");
	private static String PASS = ExtractProp.getInstance().getExtractProperty("PASS");
	private static final String Key = ExtractProp.getInstance().getExtractProperty("Key");
	private static final String IV = ExtractProp.getInstance().getExtractProperty("IV");

	private static final String Selection_Query = ExtractProp.getInstance().getExtractProperty("SelectSQL");
	private String action = null;
	private String acct_no = null;
	private String ref_no = null;
	private static final Logger log = LogManager.getLogger(Update_launcher.class);

	static {
		try {
			DB_URL = aesDecrypt(Key, IV, DB_URL);
			USER = aesDecrypt(Key, IV, USER);
			PASS = aesDecrypt(Key, IV, PASS);
		} catch (UnsupportedEncodingException ue) {
			log.info("Error when getting value from property file ", ue);
		}
	}

	@Override
	public void run() {
		if (filesExist()) {
			update_connection updateCon = new update_connection();
			updateCon.findFilesforMandate(action, acct_no, ref_no);
		} else {
			log.info("No files to process");
		}
	}

	private boolean filesExist() {
		try (Connection conn = DriverManager.getConnection(DB_URL, USER, PASS);) {
			PreparedStatement selectStmt = conn.prepareStatement(Selection_Query);
			LocalDate d=LocalDate.now();
			selectStmt.setObject(1, d);
			ResultSet rs = selectStmt.executeQuery();

//			log.info("1111");
			if (rs.next()) {
				action = rs.getString("ACTION");
				acct_no = rs.getString("Acct_no");
				ref_no = rs.getString("Unqe_ref_no");
				return true;
			} else {
				return false;
			}
		} catch (SQLException e) {
			log.error("SQL EXCEPTION in finding file from DB" + e);
		}
		return false;
	}

	public static String aesDecrypt(String key, String initVector, String encrypted)
			throws UnsupportedEncodingException {
		byte[] keyb = keyToB(key);
		byte[] ivb = keyToB(initVector);
		String dec = decrypt1(keyb, ivb, encrypted);
		return dec;
	}

	public static String decrypt1(byte[] key, byte[] initVector, String encrypted) {
		try {
			// IvParameterSpec iv = new IvParameterSpec(initVector);
			SecretKeySpec skeySpec = new SecretKeySpec(key, "AES");
			Security.addProvider(new BouncyCastleProvider());
			GCMParameterSpec gcmParameterSpec = new GCMParameterSpec(16 * 8, initVector);
			// Cipher cipher = Cipher.getInstance("AES/CBC/PKCS5PADDING");
			Cipher cipher = Cipher.getInstance("AES/GCM/NoPadding");
			// cipher.init(Cipher.DECRYPT_MODE, skeySpec, iv);
			cipher.init(Cipher.DECRYPT_MODE, skeySpec, gcmParameterSpec);

			byte[] original = cipher.doFinal(Base64.getDecoder().decode(encrypted));
			byte[] notOriginal = new String(original).replaceAll("\0", "").getBytes();
			return new String(notOriginal);
		} catch (NoSuchAlgorithmException e) {
			log.error("Algorithm not found: {}", e);
		} catch (NoSuchPaddingException e) {
			log.error("Padding not found: {}", e);
		} catch (InvalidKeyException e) {
			log.error("Invalid key: {}", e);
		} catch (InvalidAlgorithmParameterException e) {
			log.error("Invalid algorithm parameter: {}", e);
		} catch (IllegalBlockSizeException e) {
			log.error("Illegal block size: {}", e);
		} catch (BadPaddingException e) {
			log.error("Bad padding: {}", e);
		}

		return null;
	}

	public static byte[] keyToB(String key) throws UnsupportedEncodingException {

		byte[] keybyte = Base64.getDecoder().decode(key.getBytes("UTF-8"));

		return keybyte;
	}
}








