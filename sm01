	public static MobileNumber getMobileFromCBS(String ACCT_NO) {
		MobileNumber mb = new MobileNumber();
		Gson gson = new Gson();

		try {
			String urlString = Update_launcher.getCbsUrl();

			// Create request payload
			Map<String, String> requestMap = new HashMap<>();
			requestMap.put("CIF_ACCOUNT_NUMBER", ACCT_NO);
			String jsonInputString = gson.toJson(requestMap);

			// Send HTTP request
			HttpClient client = HttpClient.newHttpClient();
			HttpRequest request = HttpRequest.newBuilder().uri(URI.create(urlString))
					.header("Content-Type", "application/json; utf-8").header("Accept", "application/json")
					.POST(HttpRequest.BodyPublishers.ofString(jsonInputString)).build();

			HttpResponse<String> response = client.send(request, HttpResponse.BodyHandlers.ofString());

			if (response.statusCode() == 200) {
				String jsonResponse = response.body();

				Type responseType = new TypeToken<Map<String, String>>() {
				}.getType();
				Map<String, String> responseMap = gson.fromJson(jsonResponse, responseType);

				if (responseMap.get("RESPONSE_STATUS").equals("0")) {
					if (responseMap != null && responseMap.containsKey("ISD_CODE")
							&& responseMap.containsKey("MOBILE_NUMBER") && responseMap.containsKey("CIF_NO")) {
						String extractedIsd = responseMap.get("ISD_CODE");
						String extractedOldIsd = responseMap.get("OLD_ISD_CODE");
						String extractedMobileNo = responseMap.get("MOBILE_NUMBER");
						String extractedOldMobileNo = responseMap.get("OLD_MOBILE_NUMBER");
						String extractedCifNo = responseMap.get("CIF_NO");
						String verificationFlag = responseMap.get("VERIFICATION_FLAG");
//						log.info(extractedIsd + " " + extractedOldIsd + " " +extractedMobileNo+ " " +extractedOldMobileNo+ " " +extractedCifNo+ " " +verificationFlag);
						if (extractedCifNo.length() == 17) {
							extractedCifNo = extractedCifNo.substring(6);
						}
						List<String> validFlags = Arrays.asList("Y", "E", "S");
						List<String> invalidFlags = Arrays.asList("N", "X");
						
						if(invalidFlags.contains(verificationFlag)){
							extractedIsd = extractedOldIsd;
							extractedMobileNo = extractedOldMobileNo;
						} else if(!validFlags.contains(verificationFlag)){
							extractedIsd="";
							extractedMobileNo="";
						}
						
						mb.setIsdCode(extractedIsd != null ? extractedIsd : "");
						mb.setMobNo(extractedMobileNo != null ? extractedMobileNo : "");
						mb.setCifNo(extractedCifNo != null ? extractedCifNo : "");
					} else {
						log.info("API response doesn't contain the required fields");
					}
				} else {
					String ex_error_code = responseMap.get("ERROR_CODE");
					String ex_error_description = responseMap.get("ERROR_DESCRIPTION");
					mb.setError_code(ex_error_code != null ? ex_error_code : "");
					mb.setError_description(ex_error_description != null ? ex_error_description : "");
				}
			} else {
				log.info("API request failed to fetch mobile number: " + response.statusCode());
			}

		} catch (IOException e) {
			log.info("Error calling API to get mobile number: " + e.getMessage());
		} catch (InterruptedException e) {
			log.info("Interrupted exception occurred");
			Thread.currentThread().interrupt(); // Reset interrupt status
		} catch (NumberFormatException e) {
			log.info("Incorrect length of Cif/Mobile No");
		}

		return mb;
	}

	public String getParamConstructforTA(String action, String Umrn, String Mandate_amount, String Corp_name) {
		log.info("Preparing the SMSdata for TA");
		String Sms = "";
		Sms += "P05:";
		String P05;
		if (action.equals("A")) {
			P05 = "Amendment-";
		} else if (action.equals("C")) {
			P05 = "Registration-";
		} else {
			P05 = "Cancellation-";
		}
		Sms += P05.substring(0,
				Math.min(P05.length(), Integer.parseInt(ExtractProp.getInstance().getExtractProperty("P05"))));
		Sms += "^P27:";
		Sms += Umrn.substring(0,
				Math.min(Umrn.length(), Integer.parseInt(ExtractProp.getInstance().getExtractProperty("P27"))));
		Sms += "^P02:";
		Sms += Mandate_amount.substring(0, Math.min(Mandate_amount.length(),
				Integer.parseInt(ExtractProp.getInstance().getExtractProperty("P02"))));
		Sms += "^P23:";
		Sms += Corp_name.substring(0,
				Math.min(Corp_name.length(), Integer.parseInt(ExtractProp.getInstance().getExtractProperty("P23"))));
		log.info("TA SMSdata: " + Sms);
		return Sms;
	}

