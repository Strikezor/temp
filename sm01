	public static boolean isDigitOnly(String str) {
		for (int i = 0; i < str.length(); i++) {
	        if (!Character.isDigit(str.charAt(i))) {
	            return false;
	        }
	    }
	    return true;
	}

	public void findFilesforMandate(String action, String acct_no, String unqe_ref_no) {
		try {
			log.info("SM01_table_update process started for reference number:- " + unqe_ref_no);
			// Load the Oracle JDBC driver
			Class.forName("oracle.jdbc.driver.OracleDriver");

			// Establish the connection
			Connection conn = DriverManager.getConnection(DB_URL, USER, PASS);
			PreparedStatement selectStmt = conn.prepareStatement(SelectSQL2);
			selectStmt.setString(1, action);
			selectStmt.setString(2, acct_no);
			selectStmt.setString(3, unqe_ref_no);
			ResultSet rs = selectStmt.executeQuery();
			String Tran_Date = null;
			String Tran_Time = null;
			String sms_status = null;
			String Acct_no = "0", Alert_code = null, Alert_code_desc = null, Tran_amt = "0", Sms_flag = null,
					Sms_data = null, MOBILE_NO = "0", ISD_CODE = null, EMAIL_ID = null;
			int Sequence = 0;
			if (rs.next()) {
				log.info("Extracting the required values from ACHT for SM01_table_updation");
				Tran_Date = getDate();
				Tran_Time = getTime();
				Acct_no = rs.getString("Acct_no");
				sms_status = rs.getString("STATUS");
				String Techni_status = rs.getString("TECHNI_STATUS");
				if (action.equalsIgnoreCase("D")) {
					Alert_code = "TA";
				} else {
					if (sms_status.equalsIgnoreCase("45")) {
						Alert_code = "TA";
					} else {
						if (Techni_status.equalsIgnoreCase("03")) {
							Alert_code = "MR";
						} else if (Techni_status.equalsIgnoreCase("04")) {
							Alert_code = "MA";
						} else if (Techni_status.equalsIgnoreCase("02")) {
							Alert_code = "TA";
						}
					}
				}
				MOBILE_NO = "0";
//				ISD_CODE = rs.getString("ISD_CODE");
				EMAIL_ID = rs.getString("EMAIL_ID");
				Alert_code_desc = "Mandate";
				Tran_amt = rs.getString("Amt_in_figures");
				Sms_flag = "U";
				String Umrn = rs.getString("Ach_umrn");
				String Mandate_amount = Tran_amt;
				String Corp_name = rs.getString("Service_provider");
				String reject_reason = rs.getString("REJECT_REASON");
				if (Alert_code == "MR") {
					Sms_data = getParamConstructforMR(action, Umrn, Mandate_amount, Corp_name, reject_reason);
				} else if (Alert_code == "MA") {
					Sms_data = getParamConstructforMA(action, Umrn, Mandate_amount, Corp_name);
				} else if (Alert_code == "TA") {
					Sms_data = getParamConstructforTA(action, Umrn, Mandate_amount, Corp_name);
				}

				log.info(Tran_Date + " " + Tran_Time + " " + Acct_no + " " + Alert_code + " " + Alert_code_desc + " "
						+ Tran_amt + " " + Sms_flag + " " + Sms_data + " " + Sequence);

				Update_service sec = new Update_service();
				Sequence = sec.getSequence();

//---------------------------------Getting mob no from cbs-------------------------------------------------
				String CIF_NO = "0";
//				if (MOBILE_NO == null || ISD_CODE == null) {
				MobileNumber cbsData = getMobileFromCBS(Acct_no);
				if (cbsData != null && cbsData.getMobNo() != null) {
					ISD_CODE = cbsData.getIsdCode();
					MOBILE_NO = cbsData.getMobNo();
					CIF_NO = cbsData.getCifNo();
				} else {
					log.info("Failed to get mob no from cbs");
				}
//				}

				// Trim once and store result
				String trimmedMobile = "";
				if (MOBILE_NO != null) {
					trimmedMobile = MOBILE_NO.trim();
				}
				int length = trimmedMobile.length();

//				if (length == 14) {
//					MOBILE_NO = trimmedMobile.substring(4); // Remove first 4 chars (e.g., +91-)
//				} 
				
				if(isDigitOnly(trimmedMobile)) {
					if (length == 12 && trimmedMobile.substring(0, 2).equals("91")) {
						MOBILE_NO = trimmedMobile.substring(2);
					} else if (length == 11 && trimmedMobile.substring(0, 1).equals("0")) {
						MOBILE_NO = trimmedMobile.substring(1);
					} else if (length == 10) {
						MOBILE_NO = trimmedMobile;
					} else {
						MOBILE_NO = "0";
					}
				} else {
					MOBILE_NO = "0";
				}
				if (ISD_CODE == null || ISD_CODE.equals("") || ISD_CODE.equals(" ")) {
					ISD_CODE = "91";
				}
				if (CIF_NO == null || CIF_NO.equals("") || CIF_NO.equals(" ")) {
					CIF_NO = "0";
				}
				if (MOBILE_NO == null || MOBILE_NO.equals("") || MOBILE_NO.equals(" ")) {
					MOBILE_NO = "0";
				}
				try {
					Acct_no = Acct_no.trim().substring(0, Math.min(Acct_no.length(), 16));
				} catch (NumberFormatException | StringIndexOutOfBoundsException e) {
					log.info("Invalid acct no");
				}
				if (MOBILE_NO == null || MOBILE_NO == "0")
					Sms_flag = "X";
				PreparedStatement insertStmt = conn.prepareStatement(insertSQL);
				insertStmt.setString(1, Alert_code);
				insertStmt.setString(2, Alert_code_desc);
				insertStmt.setNull(3, java.sql.Types.VARCHAR);
				insertStmt.setLong(4, Long.parseLong(CIF_NO));
				insertStmt.setLong(5, Long.parseLong(Acct_no.trim()));
				insertStmt.setString(6, EMAIL_ID);
				insertStmt.setInt(7, Sequence);
				insertStmt.setDouble(8, Double.parseDouble(Tran_amt));
				insertStmt.setString(9, Sms_flag);
				insertStmt.setNull(10, java.sql.Types.INTEGER);
				insertStmt.setNull(11, java.sql.Types.VARCHAR);
				insertStmt.setNull(12, java.sql.Types.VARCHAR);
				insertStmt.setNull(13, java.sql.Types.VARCHAR);
				insertStmt.setNull(14, java.sql.Types.VARCHAR);
				insertStmt.setString(15, MOBILE_NO);
				insertStmt.setString(16, ISD_CODE);
				insertStmt.setString(17, Sms_data);
				insertStmt.setInt(18, Integer.parseInt(Tran_Date));
				insertStmt.setInt(19, Integer.parseInt(Tran_Time));
				insertStmt.setNull(20, java.sql.Types.VARCHAR);

				int rowsAffected = insertStmt.executeUpdate();
				log.info("Rows inserted: " + rowsAffected);

				if (sms_status.equalsIgnoreCase("41")) {
					PreparedStatement updateStmt = conn.prepareStatement(UpdateSQL);
					updateStmt.setString(1, action);
					updateStmt.setString(2, acct_no);
					updateStmt.setString(3, unqe_ref_no);
					int ans = updateStmt.executeUpdate();
					if (ans > 0)
						log.info("ACHT status updated");
					else
						log.info("ACHT status did not updated");
				} else if (sms_status.equalsIgnoreCase("43")) {
					PreparedStatement updateStmt = conn.prepareStatement(UpdateSQL2);
