@RestController
@RequestMapping("/EDMS")
public class EDMSVersion_Controller {
	private static final org.slf4j.Logger logger = LoggerFactory.getLogger(EDMSVersion_Controller.class);
	
	private static EDMS_REPO edms_REPO;
	private static String edmsVersionURL = null;
	private static String hostPublic = null;
	private static String privateKey_DigISign = null;
	private static String DocumentPath = null;
	private static String destinationPath = System.getProperty("ChannelsPropConfigPath");

	public EDMSVersion_Controller(
			@Value("${EDMS_VERSION_URL}") String edmsVersionURL,
			@Value("${HOSTpublicKeyPath}") String hostPublic,
			@Value("${PrivateKey_DigiSign}") String privateKey_DigISign,
			@Value("${DocumentPath}") String DocumentPath, 
			EDMS_REPO edms_REPO) {
		EDMSVersion_Controller.edmsVersionURL = edmsVersionURL;
		EDMSVersion_Controller.hostPublic = hostPublic;
		EDMSVersion_Controller.privateKey_DigISign = privateKey_DigISign;
		EDMSVersion_Controller.DocumentPath = DocumentPath;
		EDMSVersion_Controller.edms_REPO = edms_REPO;
	}

	@PostMapping(value = { "/EDMS_Version_Update" }, produces = { "application/json" })
	public ResponseEntity<String> EDMS_Version_Update(
			@RequestBody VersionUpdateRequest incomingReq,
			HttpServletRequest request, 
			@RequestHeader HttpHeaders headers, 
			HttpServletResponse response) throws NoSuchProviderException {

		response.setHeader("X-Content-Type-Options", "nosniff");
		response.setHeader("X-Frame-Options", "DENY");
		response.setHeader("Content-Security-Policy", "default-src 'self'");
		response.setHeader("X-XSS-Protection", "1;mode=block");
		response.setHeader("Strict-Transport-Security", "max-age=31536000; includeSubDomains; preload");
		response.setHeader("Referrer-Policy", "strict-origin-when-cross-origin");

		File documentFile = new File(DocumentPath + "/" + incomingReq.getDocumentName());
		
		if (!documentFile.exists()) {
			logger.error("Document not found in path: {}", documentFile.getAbsolutePath());
			return ResponseEntity.badRequest().body("File not found locally.");
		}

		String base64doc = encodeFileToBase64(documentFile);
		
		EDMS_Response result = callEDMSVersionApi(base64doc, incomingReq);

		if (result != null) {
			return ResponseEntity.ok("Update Processed. Check Logs.");
		} else {
			return ResponseEntity.internalServerError().body("Failed to update version in EDMS.");
		}
	}

	public static EDMS_Response callEDMSVersionApi(String base64Document, VersionUpdateRequest reqData)
			throws NoSuchProviderException {
		
		PublicKey edmsServerPublicKey = EDMSEncryption.getPublicKey(hostPublic);

		String uniqueCBSREPOServerID = EDMSEncryption.generateUniqueServerId();
		SecretKey aesKey = EDMSEncryption.generateAESkey();
		Gson gson = new GsonBuilder().serializeNulls().disableHtmlEscaping().setPrettyPrinting().create();

		VersionRequestBean request = new VersionRequestBean();
		request.setApplicationID(reqData.getApplicationID());
		request.setBranchCode(reqData.getBranchCode());
		request.setUniqueIdentifier(reqData.getUniqueIdentifier());
		
		List<VersionDocumentList> list = new ArrayList<>();
		VersionDocumentList requestDoc = new VersionDocumentList();
		requestDoc.setBase64(base64Document);
		requestDoc.setDocumentName(reqData.getDocumentName());
		requestDoc.setDocumentID(reqData.getDocumentID());
		list.add(requestDoc);
		
		request.setDocuments(list);

		TempReqBean FirstReq = new TempReqBean();
		FirstReq.setUniqueSourceServerID(uniqueCBSREPOServerID);
		FirstReq.setApplicationID(reqData.getApplicationID());
		String uniqueSourceServerID = gson.toJson(FirstReq);

		String encryptedUniqueSourceServerID = EDMSEncryption.encryptRawJSON(aesKey, edmsServerPublicKey, uniqueSourceServerID);

		logger.info("Initiation request preparation completed. Unique ID: {}", uniqueCBSREPOServerID);

		try {
			SSLUtil.turnOffSSLChecking();
		} catch (NoSuchAlgorithmException | KeyManagementException e) {
			logger.error("SSL configuration error", e);
			return null;
		}

		String responseString = null;
		try {
			logger.info("--------------------------- First EDMS Version Call Started ---------------------------");
			responseString = sendPostRequest(edmsVersionURL, encryptedUniqueSourceServerID, "");
			logger.info("--------------------------- First EDMS Version Call Ended ---------------------------");
		} catch (Exception e) {
			logger.error("UNABLE TO FETCH EDMS INITIATION RESPONSE: " + e.getMessage(), e);
			return null;
		}

		String[] tempResponse = responseString.split(",");
		String encReceiverAccessToken = tempResponse[0];
		String signedReceiverTokenHash = tempResponse[1];

		PrivateKey privateKey = EDMSEncryption.getPrivateKey(privateKey_DigISign);
		String receiverAccessToken = EDMSEncryption.decReceiverAccessToken(privateKey, encReceiverAccessToken);
		String senderTokenHash = EDMSEncryption.generateSenderTokenHash(receiverAccessToken);

		boolean hashMatched = EDMSEncryption.verifyReceiverTokenHash(edmsServerPublicKey, signedReceiverTokenHash, senderTokenHash);
		
		if (hashMatched) {
			String signedSenderTokenHash = EDMSEncryption.signSenderTokenHash(privateKey, senderTokenHash);
			String signedSenderTokenHashWithID = (signedSenderTokenHash + "," + uniqueCBSREPOServerID).replaceAll("\n", "");
			
			logger.info("Token verification successful. Proceeding to send Update payload.");
			return reuseTokenForVersion(signedSenderTokenHashWithID, request, gson, edmsVersionURL, aesKey, edmsServerPublicKey, privateKey);
		} else {
			logger.warn("Token verification failed for unique ID: {}", uniqueCBSREPOServerID);
		}

		return null;
	}

	private static EDMS_Response reuseTokenForVersion(String signedSenderTokenHashWithID, VersionRequestBean request, Gson gson,
			String url, SecretKey aesKey, PublicKey publicKey, PrivateKey privateKey) {

		EDMS_Response finalResponse = new EDMS_Response();
		String decryptedResponse = null;
		String finalJSONReq = gson.toJson(request);

		logger.info("Final Version Request JSON constructed for Document ID: {}", request.getDocuments().get(0).getDocumentID());

		String encryptedRequest = EDMSEncryption.encryptRawJSON(aesKey, publicKey, finalJSONReq);

		String finalResponseString = null;
		try {
			logger.info("--------------------------- Final EDMS Version Call Started ---------------------------");
			finalResponseString = sendPostRequest(url, encryptedRequest, signedSenderTokenHashWithID);
			logger.info("--------------------------- Final EDMS Version Call Ended ---------------------------");
		} catch (Exception e) {
			logger.error("UNABLE TO FETCH FINAL EDMS VERSION RESPONSE: " + e.getMessage(), e);
			return null;
		}

		if (finalResponseString != null && !finalResponseString.isEmpty()) {
			decryptedResponse = EDMSEncryption.decryptResponse(finalResponseString, privateKey);
			Map<String, Object> responseMap = new HashMap<>();
			ObjectMapper mapper = new ObjectMapper();
			try {
				responseMap = mapper.readValue(decryptedResponse, new TypeReference<Map<String, Object>>() {});
			} catch (JsonProcessingException e) {
				logger.error("Error parsing JSON response: " + e.getMessage());
			}

			logger.info("Final decrypted response: {}", decryptedResponse);
			List<Map<String, Object>> nameIdBeans = (List<Map<String, Object>>) responseMap.get("name_IdBeans");
			String uniqueIdentifier = (String) responseMap.get("uniqueIdentifier");

			if (nameIdBeans != null && !nameIdBeans.isEmpty()) {
				String uploadResponseCode = (String) nameIdBeans.get(0).get("uploadResponseCode");
				String documentName = (String) nameIdBeans.get(0).get("documentName");
				
				if ("00".equals(uploadResponseCode) || "809".equals(uploadResponseCode)) {
					moveFile(documentName, "/Success_Files/");
					
					EDMS_LOGS edmsLogs = new EDMS_LOGS();
					edmsLogs.setBRANCH_CODE(request.getBranchCode());
					edmsLogs.setID((String) nameIdBeans.get(0).get("documentId"));
					edmsLogs.setNAME(documentName);
					edmsLogs.setRESPONSE_CODE(uploadResponseCode);
					edmsLogs.setRESPONSE_MESSAGE((String) nameIdBeans.get(0).get("uploadResponse"));
					edmsLogs.setUNIQUE_IDENTIFIER(uniqueIdentifier);
					edmsLogs.setUPLOAD_DATE(LocalDate.now());
					edmsLogs.setFILE_TYPE("Image_Version");
					
					edms_REPO.save(edmsLogs);
				} else {
					logger.error("Update failed for document: {} with code: {}", documentName, uploadResponseCode);
					moveFile(documentName, "/Failure_Files/");
				}
			}
		}
		
		finalResponse = gson.fromJson(decryptedResponse, EDMS_Response.class);
		return finalResponse;
	}

	private static void moveFile(String documentName, String targetFolder) {
		String path = DocumentPath + "/" + documentName;
		Path src = Paths.get(path);
		Path desti = Paths.get(destinationPath + targetFolder + documentName);
		try {
			Files.move(src, desti, StandardCopyOption.REPLACE_EXISTING);
		} catch (IOException e) {
			logger.error("Error moving file: " + e.getMessage());
		}
	}

	private static String sendPostRequest(String url, String jsonBody, String token) throws IOException {
		URL obj = new URL(url);
		HttpURLConnection con = (HttpURLConnection) obj.openConnection();
		con.setRequestMethod("POST");
		con.setRequestProperty("Content-Type", "application/json");
		con.setRequestProperty("Accept", "application/json");
		con.setRequestProperty("signedSenderTokenHash", token);
		con.setDoOutput(true);
		con.setConnectTimeout(15000);
		con.setReadTimeout(45000);

		try (OutputStream os = con.getOutputStream()) {
			byte[] input = jsonBody.getBytes(StandardCharsets.UTF_8);
			os.write(input, 0, input.length);
		}

		int responseCode = con.getResponseCode();
		if (responseCode != 200) {
			try (BufferedReader br = new BufferedReader(new InputStreamReader(con.getErrorStream(), StandardCharsets.UTF_8))) {
				StringBuilder errorResponse = new StringBuilder();
				String responseLine;
				while ((responseLine = br.readLine()) != null) {
					errorResponse.append(responseLine.trim());
				}
				logger.error("HTTP Error Response: {}", errorResponse.toString());
			}
			throw new IOException("HTTP error code: " + responseCode);
		}

		try (BufferedReader br = new BufferedReader(new InputStreamReader(con.getInputStream(), StandardCharsets.UTF_8))) {
			StringBuilder response = new StringBuilder();
			String responseLine;
			while ((responseLine = br.readLine()) != null) {
				response.append(responseLine.trim());
			}
			return response.toString();
		}
	}

	private static String encodeFileToBase64(File file) {
		try {
			byte[] fileContent = Files.readAllBytes(file.toPath());
			return Base64.getEncoder().encodeToString(fileContent);
		} catch (IOException e) {
			throw new IllegalStateException("Could not read file " + file, e);
		}
	}
}






