	public void updateFileStatus(String status, String Action, String Acct_No, String Unqe_Ref_No) throws Exception {
		logger.info("Status updation strated");
		try (Connection conn = DriverManager.getConnection(DB_URL, USER, PASS);
				PreparedStatement updateStmt = conn.prepareStatement(Update_SQL)) {

			updateStmt.setString(1, status);
//	            updateStmt.setString(2, sdf.format(new Date()));
			updateStmt.setObject(2, LocalDate.now());
			updateStmt.setString(3, Action);
			updateStmt.setString(4, Acct_No);
			updateStmt.setString(5, Unqe_Ref_No); // Set the ID for the WHERE clause

			updateStmt.executeUpdate();
			logger.info("File status updated");
		} catch (Exception e) {
			// Handle SQL exceptions
			logger.error("SQLException in updating file status");
			throw e; // Rethrow the exception after logging
		}

	}

