		}

	}

	public static String returnFileName(String DRAW_BANK_ifsc, String BRCH_CODE) throws Exception {
		logger.info("Return XML file name generation strated");
		int sequenceNumber = readSequenceNumber();

		// Ensure sequence number is within the valid range
		if (sequenceNumber > MAX_SEQUENCE) {
			sequenceNumber = 1; // Reset to 1 after reaching the maximum value
		}

//		String prefix = DRAW_BANK_ifsc != null && DRAW_BANK_ifsc.length() >= 4 ? DRAW_BANK_ifsc.substring(0, 4)
//				: DRAW_BANK_ifsc;

		String LOGIN_ID = ExtractProp.getInstance().getExtractProperty("SBIN");

		String EXTRA = ExtractProp.getInstance().getExtractProperty(BRCH_CODE) != null
				? ExtractProp.getInstance().getExtractProperty(BRCH_CODE)
				: "";

//		if (DRAW_BANK_ifsc == null || DRAW_BANK_ifsc.trim().isEmpty()) {
//			LOGIN_ID = "";
//		}

		// Format the current date as ddMMyyyy
		String currentDate = new SimpleDateFormat("ddMMyyyy").format(new Date());

		// Format the sequence number to a 6-digit number with leading zeros
		String sequence = String.format("%06d", sequenceNumber);

		// Generate the filename according to the specified format
		String fileName = String.format("%s-%s-%s-%s-%s-%s-%s-%s", PROCESS_NAME, TRANS_TYPE, BANK_IDENTIFIER, EXTRA,
				LOGIN_ID, currentDate, sequence, EXTRA2);

		saveSequenceNumber(sequenceNumber + 1);
//		logger.info("Return 1");
		return fileName;
	}

	// Method to read the sequence number from the file
	private static int readSequenceNumber() {
		try {
			// Check if the sequence file exists
			File sequenceFile = new File(SEQUENCE_FILE_PATH_CR);


			if (!sequenceFile.exists()) {
				// If the file doesn't exist, create it with an initial sequence number of 1
				saveSequenceNumber(1);
				return 1;
			}
			// Read the sequence number from the file
			String sequenceStr = new String(Files.readAllBytes(Paths.get(SEQUENCE_FILE_PATH_CR))).trim();

			Integer res = null;
			try {
				res = Integer.parseInt(sequenceStr);
			} catch (NumberFormatException e) {
				// TODO Auto-generated catch block
				logger.info("NumberFormatException in readSequenceNumber");
			}
			return res;
		} catch (Exception e) {
			logger.info("Exception in readSequenceNumber");
			// In case of any error, return 1 as the default sequence number
			return 1;
		}
	}

	// Method to save the updated sequence number to the file
	private static void saveSequenceNumber(int sequenceNumber) {
		try (FileWriter writer = new FileWriter(SEQUENCE_FILE_PATH_CR)) {
			writer.write(String.valueOf(sequenceNumber));
		} catch (Exception e) {
			logger.info("Exception in saveSequenceNumber");
		}
	}

	public void xmlCreation(String fileName, String Unqe_Ref_No, String Action, String Acct_No, String Status,
			String SPONS_BANK_ifsc, String DRAW_BANK_ifsc, String Rej_Reason, String Umrn, String SPONS_BANK_micr,
			String DRAW_BANK_micr, String ifsc_bank) throws Exception {
		try {
			// Create a DocumentBuilderFactory
			LocalDate myObj1 = LocalDate.now();
			LocalTime myObj2 = LocalTime.now();
			DateTimeFormatter myFormatObj = DateTimeFormatter.ofPattern("HH:mm:ss");
			String formattedDate = myObj2.format(myFormatObj);
			DocumentBuilderFactory factory = DocumentBuilderFactory.newInstance();
			DocumentBuilder builder = factory.newDocumentBuilder();
//			logger.info("Return 2");
			// Create a new Document
			Document document = builder.newDocument();

			// Create root element
			Element root = document.createElement("Document");
			root.setAttribute("xmlns", "urn:iso:std:iso:20022:tech:xsd:pain.012.001.01");
			document.appendChild(root);

			// Create MndtAccptncRpt element
			Element mndtAccptncRpt = document.createElement("MndtAccptncRpt");
			root.appendChild(mndtAccptncRpt);

			// Create GrpHdr element
			Element grpHdr = document.createElement("GrpHdr");
			mndtAccptncRpt.appendChild(grpHdr);

			// Add MsgId and CreDtTm to GrpHdr
			Element msgId = document.createElement("MsgId");
			msgId.appendChild(document.createTextNode(Unqe_Ref_No));
			grpHdr.appendChild(msgId);

			Element creDtTm = document.createElement("CreDtTm");
			creDtTm.appendChild(document.createTextNode(myObj1 + "T" + formattedDate));
			grpHdr.appendChild(creDtTm);

			// Create InstgAgt element
			Element instgAgt = document.createElement("InstgAgt");
			grpHdr.appendChild(instgAgt);
			Element finInstnId1 = document.createElement("FinInstnId");
			instgAgt.appendChild(finInstnId1);
			Element clrSysMmbId1 = document.createElement("ClrSysMmbId");
			finInstnId1.appendChild(clrSysMmbId1);
			Element mmbId1 = document.createElement("MmbId");
			if (DRAW_BANK_ifsc != null && !DRAW_BANK_ifsc.equals("") && !DRAW_BANK_ifsc.equals(" ")) {
				mmbId1.appendChild(document.createTextNode(DRAW_BANK_ifsc));
			} else {
				mmbId1.appendChild(document.createTextNode(DRAW_BANK_micr));
			}
			clrSysMmbId1.appendChild(mmbId1);
			Element nm1 = document.createElement("Nm");
			nm1.appendChild(document.createTextNode("STATE BANK OF INDIA "));
			finInstnId1.appendChild(nm1);

			// Create InstdAgt element
