				ThreadContext.put("SPONS_BANK_IFSC", "SPONS_BANK_IFSC: " + SPONS_BANK_ifsc);
				ThreadContext.put("DRAW_BANK_IFSC", "DRAW_BANK_IFSC: " + DRAW_BANK_ifsc);
				ThreadContext.put("REJECT_REASON", "REJECT_REASON: " + Rej_Reason);
				ThreadContext.put("Umrn", "Umrn: " + Umrn);
				ThreadContext.put("BRCH_CODE", "BRCH_CODE: " + BRCH_CODE);
				logger.info("Xml creation for mandate Strated of Action: " + Action + " And of Acct_No: " + Acct_No
						+ " And of Unique_ref_no: " + Unqe_Ref_No);
				String ifsc_bank = "";
				if (SPONS_BANK_ifsc != null && !SPONS_BANK_ifsc.equals("") && !SPONS_BANK_ifsc.equals(" ")) {
					selectStmt2 = conn.prepareStatement(IFSC_code);
					selectStmt2.setString(1, SPONS_BANK_ifsc);
					rs2 = selectStmt2.executeQuery();

					if (rs2.next()) {
						ifsc_bank = rs2.getString("BANK_NAME");
					}
				}
				writeMandateFiles(Action, Acct_No, Unqe_Ref_No, Status, SPONS_BANK_ifsc, DRAW_BANK_ifsc, Rej_Reason,
						Umrn, BRCH_CODE, SPONS_BANK_micr, DRAW_BANK_micr, ifsc_bank,spn_unqe_ref);

			} else {
				logger.warn("No records found with TECHNI_STATUS 04 or 03");
			}
			conn.close();

		} catch (Exception e) {
			logger.error("SQL Exception in processing Mandate files" + e);
		} finally {
			try {
				if (rs != null)
					rs.close();
				if (selectStmt != null)
					selectStmt.close();
				if (updateStmt != null)
					updateStmt.close();
				if (conn != null)
					conn.close();
			} catch (SQLException e) {
				logger.error("SQL Exception in closing the connection");
				ThreadContext.clearAll();
			}
		}
